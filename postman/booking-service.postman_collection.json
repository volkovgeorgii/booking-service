{
  "info": {
    "name": "Booking Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "eventId",
      "value": ""
    },
    {
      "key": "reservationId",
      "value": ""
    },
    {
      "key": "userId",
      "value": "a0000000-0000-0000-0000-000000000001"
    }
  ],
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('eventId', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Event has id', () => pm.expect(json.id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rock Concert 2026\",\n  \"type\": \"CONCERT\",\n  \"totalSeats\": 5\n}"
            },
            "url": "{{baseUrl}}/api/events"
          }
        },
        {
          "name": "Get Availability",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has availableCount', () => pm.expect(pm.response.json().availableCount).to.be.a('number'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events/{{eventId}}/availability"
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Reserve Seat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('reservationId', json.reservationId);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status is RESERVED', () => pm.expect(json.status).to.eql('RESERVED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "key-reserve-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatId\": \"1\",\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/reservations/reserve"
          }
        },
        {
          "name": "Reserve Seat (idempotency check)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "key-reserve-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatId\": \"1\",\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/reservations/reserve"
          }
        },
        {
          "name": "Get Reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/reservations/{{reservationId}}"
          }
        },
        {
          "name": "Reserve Already Taken Seat (409)",
          "description": "Должен вернуть 409 — место '1' уже занято после Reserve Seat. Запускать ДО Pay/Cancel.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "key-reserve-002" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatId\": \"1\",\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/reservations/reserve"
          }
        },
        {
          "name": "Pay Reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is PAID', () => pm.expect(pm.response.json().status).to.eql('PAID'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Idempotency-Key", "value": "key-pay-001" }
            ],
            "url": "{{baseUrl}}/api/reservations/{{reservationId}}/pay"
          }
        },
        {
          "name": "Cancel Reservation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is CANCELLED', () => pm.expect(pm.response.json().status).to.eql('CANCELLED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/reservations/{{reservationId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Reservations",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{userId}}/reservations"
          }
        }
      ]
    }
  ]
}
